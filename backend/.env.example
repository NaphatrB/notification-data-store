# Database Configuration
DATABASE_URL=postgresql+asyncpg://anla:anla@db:5432/anla_db
POSTGRES_USER=anla
POSTGRES_PASSWORD=anla
POSTGRES_DB=anla_db

# Admin UI Session
# ADMIN_TOKEN: Legacy token for manual login. Generate a long random string.
ADMIN_TOKEN=your-random-token
# SESSION_SECRET: Used to sign session cookies. Generate with 'openssl rand -base64 32'
SESSION_SECRET=your-random-session-secret

# OIDC (Synology SSO)
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_ISSUER=https://sso.beaconstrike.com/webman/sso/
OIDC_DISCOVERY_URL=https://sso.beaconstrike.com/webman/sso/.well-known/openid-configuration
OIDC_FORCE_HTTPS=true

# Public Base URL for Ingestion API (used in client config)
INGESTION_PUBLIC_BASE_URL=https://anla-api.buffalo-cliff.ts.net
